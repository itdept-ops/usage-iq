# ---------------------------------------------------------------------------
# ccusage-dashboard environment
# Copy this file to .env and adjust as needed. .env is git-ignored.
# ---------------------------------------------------------------------------

# --- PostgreSQL (Docker) ---
POSTGRES_USER=ccusage
POSTGRES_PASSWORD=ccusage_dev_pw
POSTGRES_DB=ccusage
# Host port the DB is published on. 5433 avoids clashing with a 5432 already in use.
POSTGRES_HOST_PORT=5433

# --- API ---
# Connection string used by the API when run on the HOST (dotnet run).
ConnectionStrings__Default=Host=localhost;Port=5433;Database=ccusage;Username=ccusage;Password=ccusage_dev_pw

# Absolute path to your Claude Code projects directory (source of the JSONL usage logs).
Ingestion__ClaudeProjectsPath=C:\\Users\\it_de\\.claude\\projects

# IANA timezone used to bucket usage into days/months (ccusage defaults to local time).
Ingestion__DisplayTimeZone=America/New_York

# Origin allowed by CORS (the Angular dev server).
Cors__AllowedOrigin=http://localhost:4200

# --- Full-stack (docker compose --profile full) overrides ---
# Inside the compose network the API talks to the DB by service name "db".
# The API container reads the JSONL files from a read-only bind mount at /data/claude.
API_PORT=5180
WEB_PORT=4200
