{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/favicon.svg",
          "/manifest.webmanifest",
          "/icon-192.png",
          "/icon-512.png",
          "/icon-maskable-512.png",
          "/apple-touch-icon.png"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(woff|woff2|ttf|eot)",
          "/**/*.(png|jpg|jpeg|svg|webp|gif)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-network-only",
      "urls": ["/api/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 1,
        "maxAge": "1u",
        "timeout": "1u"
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/**/*__*",
    "!/**/*__*/**",
    "!/api/**"
  ]
}
