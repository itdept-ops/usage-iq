<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="clr-namespace:UsageIq.Agent.Services"
        x:Class="UsageIq.Agent.Views.MainWindow"
        Title="Usage IQ Agent"
        Width="860" Height="620" MinWidth="640" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- brand strip -->
            <RowDefinition Height="Auto"/>  <!-- status header -->
            <RowDefinition Height="Auto"/>  <!-- data sources -->
            <RowDefinition Height="*"/>     <!-- live log -->
            <RowDefinition Height="Auto"/>  <!-- footer / actions -->
        </Grid.RowDefinitions>

        <!-- Brand gradient strip -->
        <Border Grid.Row="0" Height="4" Background="{StaticResource BrandGradient}"/>

        <!-- ===== Status header ===== -->
        <Border Grid.Row="1" Background="{StaticResource BgPanel}" Padding="20,16" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title + connection state -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Usage IQ" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Agent" FontSize="20" FontWeight="Light" Margin="6,0,0,0" Foreground="{StaticResource BrandTeal}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Ellipse x:Name="StateDot" Width="9" Height="9" VerticalAlignment="Center" Fill="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="StateText" Text="Not configured" Margin="8,0,0,0" Foreground="{StaticResource TextSecondary}" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ServerText" Text="" Margin="12,0,0,0" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Session metrics -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="14,0">
                        <TextBlock x:Name="TokensValue" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrandTeal}" HorizontalAlignment="Right"/>
                        <TextBlock Text="tokens this session" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <StackPanel Margin="14,0">
                        <TextBlock x:Name="RowsValue" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrandPurple}" HorizontalAlignment="Right"/>
                        <TextBlock Text="rows synced" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <StackPanel Margin="14,0">
                        <TextBlock x:Name="NextRunValue" Text="—" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrandBlue}" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="NextRunLabel" Text="next scan" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Data sources ===== -->
        <Border Grid.Row="2" Background="{StaticResource Bg}" Padding="20,12,20,4">
            <StackPanel>
                <TextBlock Text="DATA SOURCES" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                <ItemsControl x:Name="SourcesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type s:SourceInfo}">
                            <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,10,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                 Fill="{Binding Present, Converter={StaticResource PresentToBrush}}"/>
                                        <TextBlock Text="{Binding Display}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Path}" Foreground="{StaticResource TextMuted}" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Margin="0,5,0,0" ToolTip="{Binding Path}"/>
                                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}"
                                               FontSize="12" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ===== Live log / request view ===== -->
        <Border Grid.Row="3" Background="{StaticResource Bg}" Padding="12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="LIVE ACTIVITY" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMuted}" Margin="6,4,0,6"/>

                <ListBox x:Name="LogList" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" Padding="6,2">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type s:LogLine}">
                            <Grid TextElement.FontFamily="{StaticResource MonoFont}" TextElement.FontSize="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Time}" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Tag}" FontWeight="SemiBold"
                                           Foreground="{Binding Severity, Converter={StaticResource SeverityToBrush}}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Text}" TextWrapping="Wrap"
                                           Foreground="{Binding Severity, Converter={StaticResource SeverityToText}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ===== Footer / actions ===== -->
        <Border Grid.Row="4" Background="{StaticResource BgPanel}" Padding="20,12" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="LastSyncText" Text="No sync yet"
                           Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="SettingsButton" Content="Settings" Style="{StaticResource GhostButton}" Margin="0,0,10,0" Click="OnSettings"/>
                    <Button x:Name="SyncButton" Content="Sync now" Style="{StaticResource GhostButton}" Margin="0,0,10,0" Click="OnSyncNow"/>
                    <Button x:Name="PauseButton" Content="Pause" Style="{StaticResource PrimaryButton}" Width="110" Click="OnPauseResume"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
