<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UsageIq.Agent.Views.SettingsWindow"
        Title="Usage IQ Agent — Settings"
        Width="560" Height="700" MinWidth="520" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Height="4" Background="{StaticResource BrandGradient}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,2"/>
                <TextBlock Text="Stored in ~/.usage-iq/config.json. The ingest key is kept separately in ~/.usage-iq/reporter.key."
                           Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,18"/>

                <!-- Connection -->
                <TextBlock Text="CONNECTION" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>

                <TextBlock Text="Server URL" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="UrlBox" Style="{StaticResource Field}"/>
                <TextBlock Text="The Usage IQ API base URL, e.g. https://usageiq.online" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="2,4,0,14"/>

                <TextBlock Text="Ingest key" Style="{StaticResource FieldLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="KeyBox" Grid.Column="0" Style="{StaticResource FieldPassword}"/>
                    <TextBox x:Name="KeyPlain" Grid.Column="0" Style="{StaticResource Field}" Visibility="Collapsed"/>
                    <Button x:Name="RevealButton" Grid.Column="1" Content="Show" Style="{StaticResource GhostButton}"
                            Margin="8,0,0,0" Width="64" Click="OnToggleReveal"/>
                </Grid>
                <TextBlock x:Name="KeyHint" Text="" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="2,4,0,4" TextWrapping="Wrap"/>
                <TextBlock FontSize="11" Margin="2,0,0,14" TextWrapping="Wrap">
                    <Run Text="Generate one on the " Foreground="{StaticResource TextMuted}"/>
                    <Hyperlink x:Name="ReporterLink" Click="OnOpenReporterPage" Foreground="{StaticResource BrandBlue}">Reporter page</Hyperlink>
                    <Run Text=" of your dashboard (top nav → Reporter → Generate key). Shown once; treat it like a password." Foreground="{StaticResource TextMuted}"/>
                </TextBlock>

                <TextBlock Text="Machine name override" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="MachineBox" Style="{StaticResource Field}"/>
                <TextBlock Text="Label this machine reports under (defaults to the OS machine name)." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="2,4,0,18"/>

                <!-- Scanning -->
                <TextBlock Text="SCANNING" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>

                <TextBlock Text="Sync interval (seconds)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="IntervalBox" Style="{StaticResource Field}"/>
                <TextBlock Text="How often to scan in watch mode (5–3600)." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="2,4,0,14"/>

                <TextBlock Text="Claude Code projects path" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ClaudeBox" Style="{StaticResource Field}"/>
                <TextBlock Text="Defaults to ~/.claude/projects" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="2,4,0,14"/>

                <TextBlock Text="Codex sessions path" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="CodexBox" Style="{StaticResource Field}"/>
                <TextBlock Text="Defaults to ~/.codex" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="2,4,0,14"/>

                <TextBlock Text="Gemini / Antigravity path" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="GeminiBox" Style="{StaticResource Field}"/>
                <TextBlock Text="Defaults to ~/.gemini — captures Google Antigravity (~/.gemini/antigravity/brain) and the Gemini CLI." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="2,4,0,18"/>

                <!-- Startup -->
                <TextBlock Text="STARTUP" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                <CheckBox x:Name="RunOnStartupCheck" Style="{StaticResource ToggleCheck}" Content="Run Usage IQ Agent when I sign in"/>
                <CheckBox x:Name="StartMinimizedCheck" Style="{StaticResource ToggleCheck}" Content="Start minimized to the tray"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" Padding="24,14" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" Text="" Foreground="{StaticResource SevWarning}" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,10,0" Click="OnCancel"/>
                    <Button Content="Save" Style="{StaticResource PrimaryButton}" Width="110" Click="OnSave"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
